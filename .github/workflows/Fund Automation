name: Fund Automation
on:
  schedule:
    - cron: '30 7 * * 1-5' # 北京时间 15:30
  workflow_dispatch:      # 允许手动点击按钮运行测试

jobs:
  run-script:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: '3.10'
      - run: pip install pandas numpy requests matplotlib
      - name: Run
        env:
          EMAIL_SENDER: ${{ secrets.EMAIL_SENDER }}
          EMAIL_PASSWORD: ${{ secrets.EMAIL_PASSWORD }}
        run: python main.py
